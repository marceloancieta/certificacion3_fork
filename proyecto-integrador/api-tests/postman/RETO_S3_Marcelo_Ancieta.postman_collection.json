  "item": [
    {
      "name": "01 · GET Listar users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code es 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Devuelve la lista completa de 10 usuarios', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "    pm.expect(jsonData.length).to.eql(10);",
              "});",
              "",
              "pm.test('Tiempo de respuesta menor a 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 · GET Detalle de un user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Contrato de la API: si la estructura cambia, este test falla",
              "const userSchema = {",
              "    type: 'object',",
              "    required: ['id', 'name', 'username', 'email'],",
              "    properties: {",
              "        id: { type: 'integer' },",
              "        name: { type: 'string' },",
              "        username: { type: 'string' },",
              "        email: { type: 'string' }",
              "    }",
              "};",
              "",
              "pm.test('El user cumple el contrato (JSON Schema)', function () {",
              "    pm.response.to.have.jsonSchema(userSchema);",
              "});",
              "",
              "pm.test('El user pedido es el id=1', function () {",
              "    pm.expect(pm.response.json().id).to.eql(1);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 · POST Crear user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Se ejecuta ANTES de enviar el request: genera un nombre único",
              "const name = 'User_' + Date.now();",
              "pm.collectionVariables.set('dynamic_name', name);",
              "console.log('Nombre generado:', name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code es 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "",
              "pm.test('El Nombre  devuelto es el que enviamos', function () {",
              "    const enviado = pm.collectionVariables.get('dynamic_name');",
              "    pm.expect(pm.response.json().name).to.eql(enviado);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{dynamic_name}}\",\n  \"username\": \"mancieta\",\n  \"email\": \"marcelo.ancieta@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
